# =========================================================================
# Job Market Intelligence Analyzer - Environment Variables Template
# Copy this file to '.env' and fill in your values.
# Do NOT commit your actual '.env' file containing secrets to version control.
# =========================================================================

# Django Secret Key (Set a strong, unique secret key in production)
SECRET_KEY=django-insecure-o=uhq)wb7&wy!++dl4+o32bf&rc462p_fq0rtvnm6wy2knnxol

# Toggle Debug mode (Set to False in production)
DEBUG=True

# Comma-separated list of allowed hostnames (e.g. your-app.onrender.com,localhost)
ALLOWED_HOSTS=*

# Port configuration (Defaults to 8000; Render sets this dynamically)
PORT=8000

# JSearch API Key (RapidAPI)
# Sign up at https://rapidapi.com/letscrape-6s7rjzz9ad/api/jsearch
RAPIDAPI_KEY=your_jsearch_rapidapi_key_here

# Redis URL for caching (Fallbacks to LocMemCache if not reachable or not provided)
# Local Redis default: redis://127.0.0.1:6379/1
# Production Redis (e.g. Render Redis): rediss://red-xxxxxxxxxx:password@host:port
REDIS_URL=redis://127.0.0.1:6379/1

# Production Database URL (e.g. PostgreSQL on Render)
# Fallbacks to SQLite (db.sqlite3) in the project root if omitted
# Format: postgres://user:password@host:port/database_name
# DATABASE_URL=postgres://postgres_user:postgres_password@postgres_host:5432/postgres_db
